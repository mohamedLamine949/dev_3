{
  "expo": {
    "name": "Flash Market",
    "slug": "flash-market",
    "scheme": "flashmarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/388e45d1-3af0-4012-b1c8-68ecd8748b7a",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chapchap.flashmarket",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.chapchap.flashmarket",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#16a34a",
          "defaultChannel": "default"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Flash Market utilise votre position pour vous montrer les annonces publiées près de chez vous et afficher la distance qui vous sépare de chaque vendeur. Par exemple, les annonces de la page d'accueil sont triées de la plus proche à la plus éloignée et chaque annonce indique « à 2,5 km de vous ». Votre position n'est jamais partagée avec les autres utilisateurs.",
          "locationAlwaysAndWhenInUsePermission": false,
          "locationAlwaysPermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Flash Market accède à vos photos pour ajouter des images à vos annonces et à votre profil."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REMPLACER_PAR_ID_CLIENT_IOS_GOOGLE"
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "388e45d1-3af0-4012-b1c8-68ecd8748b7a"
      }
    },
    "owner": "mohamedlamine_404"
  }
}
